# =============================================================================
# Ideart ERP — Exemplo de configuração de ambiente
# Copie este arquivo para .env e ajuste os valores. NUNCA commite o .env real.
# =============================================================================

# Ambiente: "development" ou "production"
NODE_ENV=development

# Porta HTTP do Node (o Nginx/Caddy na frente cuida do 80/443)
PORT=3000

# -----------------------------------------------------------------------------
# Banco de dados (MySQL)
# Em produção, crie um usuário dedicado (não use root) e gere uma senha forte.
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_USER=ideart_erp
DB_PASSWORD=troque-por-uma-senha-forte
DB_NAME=ideart_erp

# -----------------------------------------------------------------------------
# Segurança
# -----------------------------------------------------------------------------
# Chave de assinatura do JWT. Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-uma-string-aleatoria-de-no-minimo-48-caracteres

# Origens permitidas pelo CORS (separadas por vírgula, sem barra final).
# Em dev: http://localhost:3000
# Em prod: https://erp.seudominio.com.br
CORS_ORIGIN=http://localhost:3000

# URL base pública da API (usada no Swagger, opcional em prod)
# APP_BASE_URL=https://erp.seudominio.com.br

# -----------------------------------------------------------------------------
# Envio de email (recuperação de senha)
# Opcional: se SMTP_HOST estiver vazio, o sistema apenas imprime o link no log
# do servidor (útil em dev). Para enviar por email de verdade, preencha todos
# os campos abaixo. Veja o README para o passo-a-passo do Brevo/Gmail/Mailtrap.
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=seu-login-smtp
# SMTP_PASS=sua-chave-smtp
# SMTP_FROM="Ideart ERP <nao-responda@seudominio.com.br>"
# SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Opcional — só habilite em ambientes de demo
# Quando "true", insere produtos/clientes/pedidos fictícios no primeiro boot.
# -----------------------------------------------------------------------------
SEED_EXAMPLE_DATA=false
